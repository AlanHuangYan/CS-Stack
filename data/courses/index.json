          {"name": "CSS 选择器与优先级", "description": "类、ID、属性、伪类选择器", "exercise": "编写 CSS 选择器优先级排序练习"},
          {"name": "Flexbox 布局", "description": "主轴、交叉轴、flex-grow/shrink/basis", "exercise": "用 Flexbox 实现一个响应式导航栏"}
